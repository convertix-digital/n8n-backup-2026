nst valList = cols.map(c => esc(payload[c])).join(', ');\n\n  let sql_query;\n\n  if (op === 'insert') {\n    sql_query = `INSERT INTO \\`${db}\\`.\\`${table}\\` (${colList}) VALUES (${valList});`;\n  } else {\n    const updates = cols.map(c => `\\`${c}\\`=VALUES(\\`${c}\\`)`).join(', ');\n    sql_query = `INSERT INTO \\`${db}\\`.\\`${table}\\` (${colList}) VALUES (${valList}) ON DUPLICATE KEY UPDATE ${updates};`;\n  }\n\n  return { json: { ok: true, jobId, sql_query } };\n\n} catch (e) {\n  return { json: { ok: false, jobId, error: e.message || String(e) } };\n}\n"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[2144,192],"id":"a7008be8-5b6e-4fc9-b01e-a492249b7279","name":"Code (gera SQL seguro por item)"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":3},"conditions":[{"id":"21132d08-929d-421e-8f5c-253011ba0643","leftValue":"={{$json.skip === true}}","rightValue":"","operator":{"type":"boolean","operation":"true","singleValue":true}}],"combinator":"and"},"options":{}},"type":"n8n-nodes-base.if","typeVersion":2.3,"position":[2368,192],"id":"eaf9da84-00df-458d-baf9-7ff18fcfe067","name":"IF (pula os vazios)"},{"parameters":{"operation":"executeQuery","query":"UPDATE ctx_convertix.write_jobs\nSET status='error',\n    last_error=COALESCE(last_error,'erro no worker'),\n    processed_at=NOW()\nWHERE id={{$json.jobId}};\n","options":{"connectionTimeoutMillis":30,"connectionLimit":10,"queryBatching":"single"}},"type":"n8n-nodes-base.mySql","typeVersion":2.5,"position":[2592,-32],"id":"922b0cfa-da87-455a-8877-3b93bb73a844","name":"MySQL (mark error)","retryOnFail":true,"maxTries":5,"waitBetweenTries":5000,"credentials":{"mySql":{"id":"0IDpbdZyV1ra1ED3","name":"MySQL 03 ctx_convertix"}}},{"parameters":{"operation":"executeQuery","query":"{{$json.sql_query}}","options":{"connectionTimeoutMillis":30,"connectionLimit":10,"queryBatching":"independently","detailedOutput":false}},"type":"n8n-nodes-base.mySq