io?\n{{ $json.body.site }}\n\ninstagram\n{{ $json.body.instagram }}\n\nQual é a sua faixa de FATURAMENTO MENSAL?\n{{ $json.body.faixaFaturamento }}\n\nRecomendamos um valor a partir de R$40,00 por dia (R$1.200 por mês) para serem investidos nos anúncios, desconsiderando nossa mão de obra.\nEsse valor mínimo está de acordo com sua realidade hoje?\n{{ $json.body.faixaFaturamento }}\n\nPara quando você precisa de um gestor de tráfego iniciando na sua estrutura?\n{{ $json.body.quandoGestor }}\n\nTodos os campos:\n{{ $json.body.toJsonString().replaceAll('\",\"','\",\\n\\n\"').replaceAll('\":\"','\":\\n\"') }}","dueDate":"={{ $now }}","dueDateTime":false,"markdownContent":false,"notifyAll":true,"priority":1,"status":"02. abordagens da semana","tags":[]}},"id":"cbac0914-32b0-4faa-ad00-244c3d5f6e2b","name":"ClickUp","type":"n8n-nodes-base.clickUp","typeVersion":1,"position":[224,-144],"retryOnFail":false,"maxTries":5,"waitBetweenTries":5000,"credentials":{"clickUpOAuth2Api":{"id":"JtBih6teXSwBbyK9","name":"ClickUp Convertix"}}},{"parameters":{"jsCode":"// Para retirar caracteres especiais do telefone\nvar search=\"\\\\D\";\nvar searchRegExp=new RegExp(search,'g');\n\nfor (const item of $input.all()) {\n\n  // ph55\n  item.json.ph55 = item.json.body.phoneFinal.replaceAll(searchRegExp, \"\");\n  item.json.ph55 = (item.json.ph55.length >= 8 && item.json.ph55.length <= 11) ? '55' + item.json.ph55 : '' + item.json.ph55;\n\n// em\n  item.json.em = item.json.body.emailFinal.toLowerCase();\n  \n// fn\n  item.json.fn = item.json.body.firstnameFinal.split(' ')[0].toLowerCase();\n  \n// ln\n  item.json.ln = item.json.body.firstnameFinal.substring(item.json.body.firstnameFinal.split(' ')[0].length).trim().toLowerCase();\n  \n  \n}\n\nreturn $input.all();"},"id":"e1441c95-0b30-4329-9c91-57e637f28fc7","name":"DefineUserVariables","type":"n8n-nodes-base.code","typeVersion":2,"position":[224,160]},{"parameters":{"assignments":{"assignments":[{"id":"ab5327c1-eacf-4376-b9e8-cb57c09e2072","na