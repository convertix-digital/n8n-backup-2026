8399-b721bb0811de","name":"Acima de R$ 20 mil","disabled":true},{"parameters":{"jsCode":"// 1) Valida se custom_fields existe e possui ao menos 3 itens\nif (\n  !items[0].json.custom_fields ||\n  !Array.isArray(items[0].json.custom_fields) ||\n  items[0].json.custom_fields.length < 3\n) {\n  throw new Error(\"O array custom_fields não existe ou possui menos de 3 itens.\");\n}\n\nconst campo = items[0].json.custom_fields[2];\n\n// 2) Garante que o campo possui options configuradas em type_config\nconst options = campo.type_config?.options;\nif (!options || !Array.isArray(options)) {\n  throw new Error(\"O campo não possui opções configuradas em type_config.options\");\n}\n\n// 3) Encontra a opção cujo orderindex corresponde ao valor selecionado\nconst selecionada = options.find(opt => opt.orderindex === campo.value);\nif (!selecionada) {\n  throw new Error(`Nenhuma opção encontrada para o valor ${campo.value}`);\n}\n\n// 4) Utiliza regex para capturar o conteúdo dentro dos colchetes\nconst regex = /\\[([^\\]]+)\\]/;\nconst match = selecionada.name.match(regex);\nconst tag = match ? match[1] : \"\";\n\n// 5) Retorna os valores extraídos\nreturn [\n  {\n    json: {\n      customFieldValue: campo.value,\n      customFieldName: selecionada.name,\n      tag: tag\n    }\n  }\n];\n"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[448,-144],"id":"68fc80c6-33e9-4583-9a19-280697032dd9","name":"Code"},{"parameters":{"resource":"messages-api","instanceName":"ctxvendas","remoteJid":"={{ $vars.WHATS_grupoCTXComercial || \"120363344613347234@g.us\" }}","messageText":"=*[NOVO LEAD]* {{ $json.customFieldName }}\n\n{{ $('ClickUp').item.json.name }}\nLink do clickup: {{ $('ClickUp').item.json.url }}\nEtapa: {{ $('ClickUp').item.json.status.status }}","options_message":{}},"type":"n8n-nodes-evolution-api.evolutionApi","typeVersion":1,"position":[672,-144],"id":"2dc2ca80-998e-4b9f-ab33-6e98ac2040f3","name":"Avisa NOVO LEAD","credentials":{"evolutionApi":{"id":"rxWAYLai2uHqyf7e"