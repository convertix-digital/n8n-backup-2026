{"updatedAt":"2026-01-27T15:50:24.964Z","createdAt":"2026-01-06T04:09:39.140Z","id":"o2kdwjkm0oWZ61W8","name":"[N8N] [INTERNO] Generate Audit (v1.0)","active":false,"isArchived":false,"nodes":[{"parameters":{},"type":"n8n-nodes-base.manualTrigger","typeVersion":1,"position":[0,-144],"id":"e4f76570-398c-45c3-941c-306a01d53af3","name":"When clicking ‘Test workflow’"},{"parameters":{"jsCode":"/**\n * Nó: Function\n * Descrição: Une sections e locations em linhas para inserção em banco de dados.\n */\n\n// Pega o JSON inteiro (configure este Function node para receber como único item o objeto de relatórios)\nconst reportData = items[0].json;\n\n// Array que receberá as linhas resultantes\nconst flattenedRows = [];\n\n// Itera sobre cada relatório (e.g. \"Credentials Risk Report\", \"Nodes Risk Report\" etc.)\nObject.entries(reportData).forEach(([reportName, report]) => {\n  const { risk, sections } = report;\n  sections.forEach(section => {\n    // Processa apenas se houver lista de locations\n    if (Array.isArray(section.location)) {\n      section.location.forEach(loc => {\n        flattenedRows.push({\n          reportName,                             // Nome do relatório\n          risk,                                   // Tipo de risco\n          sectionTitle: section.title,            // Título da seção\n          sectionDescription: section.description,// Descrição da seção\n          recommendation: section.recommendation, // Recomendação da seção\n          ...loc                                  // Todas as propriedades do location (kind, id, name, nodeId etc.)\n        });\n      });\n    }\n  });\n});\n\n// Retorna cada objeto como um item para o próximo nó\nreturn flattenedRows.map(row => ({ json: row }));\n"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[448,-48],"id":"b13306cb-6ce4-4018-bf9b-0a7f5b97f294","name":"Code"},{"parameters":{"table":{"__rl":true,"value":"n8n_audit","mode":"list","cachedResultName":"n8n_audit"},"options":{"connection