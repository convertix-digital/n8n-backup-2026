\n} else {\n  remainingContent = variableContent.trim();\n}\n\nreturn [\n  {\n    json: {\n      extractedContent: extractedContent,\n      remainingContent: remainingContent    }\n  }\n];\n"},"id":"cd808029-1a46-4fad-9065-c726960fb427","name":"Split Message","type":"n8n-nodes-base.code","position":[1040,140],"typeVersion":2},{"parameters":{"graphApiVersion":"=v20.0","node":"=search?type=adinterest&q={{ $json.remainingContent }}\n&limit=1000000&locale=pt_BR ","edge":"="},"id":"6f541faf-7756-415e-8391-5470166b8a01","name":"Connect to Graph API","type":"n8n-nodes-base.facebookGraphApi","position":[1260,140],"typeVersion":1,"retryOnFail":true,"maxTries":5,"waitBetweenTries":5000,"credentials":{"facebookGraphApi":{"id":"ke9pZRQIoZp3B2la","name":"Facebook Graph Convertix"}}},{"parameters":{"jsCode":"let inputData = items[0].json; // get the input data\nlet outputData = [];\n\nfor(let key in inputData) {\n    if(inputData.hasOwnProperty(key)) {\n        let itemKey = key;\n        let itemValue = inputData[key];\n        \n        for(let subKey in itemValue) {\n            if(itemValue.hasOwnProperty(subKey)) {\n                let formattedItem = {\n                    'Item': itemKey,\n                    'SubItem': subKey,\n                    'Value': itemValue[subKey]\n                };\n                \n                outputData.push({json: formattedItem});\n            }\n        }\n    }\n}\n\nreturn outputData;"},"id":"394a34ce-f56d-4a79-8fbb-f37681cbee76","name":"Split Interests into a Table","type":"n8n-nodes-base.code","position":[1700,40],"typeVersion":2},{"parameters":{"jsCode":"let outputData = items.map(item => {\n    let data = item.json.Value;\n    \n    return {\n        json: {\n            'name': data.name,\n            'audience_size_lower_bound': data.audience_size_lower_bound,\n            'audience_size_upper_bound': data.audience_size_upper_bound,\n            'path': data.path,\n            'description': data.description,\n            'topic': data.topic\n        }\n    };\n});\n\nreturn outputData;"},"id":"1d3f66a4-322f-4398-b887-52ccd2f2f5fe","name":"Get variables","type":"n8n-nodes-base.code","position":[1920,40],"typeVersion":2},{"parameters":{"operation":"toFile","fileFormat":"csv"},"id":"082ddf0f-29ef-424a-a2a2-4bf9e260657f","name":"Create a Spreadsheet","type":"n8n-nodes-base.spreadsheetFile","position":[2140,40],"typeVersion":2,"retryOnFail":true,"maxTries":5,"waitBetweenTries":5000},{"parameters":{"operation":"sendDocument","chatId":"={{ $('Get interest name').item.json.message.chat.id }}","binaryData":true,"additionalFields":{"fileName":"report.csv"}},"id":"44e4f97a-cd86-4b60-b761-49dc46f7e36b","name":"Send the Spreadsheet file","type":"n8n-nodes-base.telegram","position":[2360,40],"typeVersion":1,"retryOnFail":true,"maxTries":5,"waitBetweenTries":5000,"webhookId":"1ee007de-06d0-44f5-9edd-0b3193c26c5a","credentials":{"telegramApi":{"id":"MBAGGxhvJ0OgtF25","name":"Telegram ConvertixBot"}}},{"parameters":{"content":"## Facebook API\n\nTo get the API Key you need to follow these steps:\nhttps://developers.facebook.com/docs/commerce-platform/setup/api-setup/","height":296.5325040542755,"width":948.6687115198118},"id":"22bc6129-7d10-46fd-98e2-0f3fc7a93344","name":"Sticky Note","type":"n8n-nodes-base.stickyNote","position":[680,-180],"typeVersion":1},{"parameters":{"conditions":{"number":[{"value1":"={{ $json.data }}","operation":"isNotEmpty"}]}},"id":"7e70978d-6610-4abc-b94f-4fdb1472c17b","name":"Check message contents1","type":"n8n-nodes-base.if","position":[1480,140],"typeVersion":1},{"parameters":{"chatId":"={{ $('Get interest name').item.json.message.chat.id }}","text":"=Nenhum interesse encontrado para \"{{ $('Get interest name').item.json.message.text }}\"","additionalFields":{}},"id":"73faaf4a-801b-43d4-8d97-99bbcd7c1e82","name":"Send the Spreadsheet file1","type":"n8n-nodes-base.telegram","position":[1700,240],"typeVersion":1,"retryOnFail":true,"maxTries":5,"waitBetweenTries":5000,"webho