e.getDate() - i); // Retrocede i dias\n    entries.push({\n      json: {\n        ...item.json,\n        since: dateEntry.toISOString().split(\"T\")[0],\n        until: dateEntry.toISOString().split(\"T\")[0]\n      }\n    });\n  }\n\n  return entries;\n}\n\n// Processa cada item do input e gera a saída\nconst output = input.flatMap(item => generateLastDaysEntries(item));\n\n// Ordena da data mais atual para a mais antiga\noutput.sort((a, b) => new Date(b.json.until) - new Date(a.json.until));\n\nreturn output;\n"},"id":"63aee84f-3ece-4f85-be95-248a5823480a","name":"Code: últimos 30 dias","type":"n8n-nodes-base.code","typeVersion":2,"position":[848,1888]},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"fa757669-c4fc-4bde-8203-9a9bedb7e6cf","leftValue":"={{ $json.db_name }}","rightValue":"","operator":{"type":"string","operation":"exists","singleValue":true}},{"id":"f89cfac3-fa30-4346-9c25-65a3a16dc4ba","leftValue":"={{ $json.act_account_id }}","rightValue":"","operator":{"type":"string","operation":"exists","singleValue":true}}],"combinator":"and"},"options":{}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[400,1888],"id":"5085e61a-f615-4399-af5d-5740e9c91f8d","name":"Filter: Contas válidas"},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"fa757669-c4fc-4bde-8203-9a9bedb7e6cf","leftValue":"={{ $json.db_name }}","rightValue":"","operator":{"type":"string","operation":"exists","singleValue":true}},{"id":"f89cfac3-fa30-4346-9c25-65a3a16dc4ba","leftValue":"={{ $json.google_ads }}","rightValue":"","operator":{"type":"string","operation":"exists","singleValue":true}},{"id":"9d5417d3-4530-4634-a5f1-ec23a0b1e744","leftValue":"={{ $json.SIGLA }}","rightValue":"FNT|TA|DEA","operator":{"type":"string","operation":"notRegex"}}],"combinator":"and"},"options":{}},"type":"n8n-nodes-base.filter