mbos os JSONs\nlet combinedData = [];\n\n// Adiciona os dados do primeiro JSON ao array combinado\ncombinedData = combinedData.concat(jsonData1);\n\n// Adiciona os dados do segundo JSON ao array combinado\ncombinedData = combinedData.concat(jsonData2);\n\n// Retorna o JSON combinado como saída\nreturn [{ json: { data: combinedData } }];"},"id":"353681c7-6296-4fe3-9176-5c403803ecec","name":"Code1","type":"n8n-nodes-base.code","typeVersion":2,"position":[672,-496]},{"parameters":{"mode":"combineBySql","query":"SELECT input1.*,input2.* FROM input1 LEFT JOIN input2 ON input1.account_id = input2.account_id"},"id":"de7acdc7-9417-4ed2-924a-71a87ac30a18","name":"Merge","type":"n8n-nodes-base.merge","typeVersion":3,"position":[1792,-496],"alwaysOutputData":false},{"parameters":{"graphApiVersion":"={{ $vars.FB_API_VERSION }}","node":"={{ $vars.BM_CONVERTIX }}","edge":"owned_ad_accounts","options":{"fields":{"field":[{"name":"=account_id,account_status,balance,amount_spent,spend_cap,name,id,is_prepay_account,currency"}]},"queryParameters":{"parameter":[{"name":"limit","value":"1000"},{"name":"filtering","value":"=[{\"field\":\"name\",\"operator\":\"CONTAIN\", \"value\":\"{{ $vars.filtroContaCTX }}\"}]"}]}}},"id":"c50812b5-884b-4ba3-975e-6def5a458494","name":"[CTX] Owned Ad Accounts1","type":"n8n-nodes-base.facebookGraphApi","position":[224,-496],"typeVersion":1,"retryOnFail":false,"maxTries":5,"waitBetweenTries":5000,"credentials":{"facebookGraphApi":{"id":"H6PFvm9bXWMhKITz","name":"Facebook Access Token"}}},{"parameters":{"graphApiVersion":"={{ $vars.FB_API_VERSION }}","node":"={{ $vars.BM_CONVERTIX }}","edge":"client_ad_accounts","options":{"fields":{"field":[{"name":"=account_id,account_status,balance,amount_spent,spend_cap,name,id,is_prepay_account,currency"}]},"queryParameters":{"parameter":[{"name":"limit","value":"1000"},{"name":"filtering","value":"=[{\"field\":\"name\",\"operator\":\"CONTAIN\", \"value\":\"{{ $vars.filtroContaCTX }}\"}]"}]}}},"id":"95cf22b6-e625-4ed4-82b5-7277a9e7324d","name":"[CTX] Client Ad Accounts","type":"n8n-nodes-base.facebookGraphApi","position":[448,-496],"typeVersion":1,"retryOnFail":true,"maxTries":5,"waitBetweenTries":5000,"credentials":{"facebookGraphApi":{"id":"H6PFvm9bXWMhKITz","name":"Facebook Access Token"}}},{"parameters":{"jsCode":"// Obtém os dados do JSON\nconst data = $node[\"Aggregate\"].json.data;\n\n// Pega o id_message da etapa anterior (é sempre igual)\nconst id_message = data?.[0]?.id_message ?? null;\n\nfunction dataDeOntem() {\n  return new Date(Date.now() - 86400000).toISOString().substring(0, 10);\n}\n\n// Mapeia os status das contas para melhor leitura\nconst accountStatusMap = {\n  1: \"ACTIVE\",\n  2: \"DISABLED\",\n  3: \"UNSETTLED\",\n  7: \"PENDING_RISK_REVIEW\",\n  8: \"PENDING_SETTLEMENT\",\n  9: \"IN_GRACE_PERIOD\",\n  100: \"PENDING_CLOSURE\",\n  101: \"CLOSED\",\n  201: \"ANY_ACTIVE\",\n  202: \"ANY_CLOSED\",\n};\n\n// Arrays para armazenar as contas conforme a classificação\nconst greenAccounts = [];\nconst redAccounts = [];\nconst yellowAccounts = [];\n\n// Processa cada conta\ndata.forEach((account) => {\n  const name = account.name;\n\n  const spendFloat = parseFloat(account.spend) || 0;\n  const spendFormatted = account.spend ? String(account.spend).replace(\".\", \",\") : \"0,00\";\n\n  // Calcula saldo restante para contas pré-pagas; 9999999 indica que não é pré-paga\n  const saldo = account.is_prepay_account\n    ? (Number(account.spend_cap) - Number(account.amount_spent)) / 100\n    : 9999999;\n\n  const saldoFormatted = String(saldo).replace(\".\", \",\");\n\n  // Converte a moeda para seu símbolo correspondente\n  let currency = account.currency;\n  switch (currency) {\n    case \"EUR\":\n      currency = \"€\";\n      break;\n    case \"BRL\":\n      currency = \"R$\";\n      break;\n    case \"USD\":\n      currency = \"$\";\n      break;\n    default:\n      currency = currency || \"\";\n      break;\n  }\n\n  // Obtém o status legível\n  const status = accountStatusMap[account.account_status] || \"UNKNOWN\";\n\n  /*\n    Classifica a conta:\n    - Se não estiver ativa ou o saldo for zero => red (conta com problema)\n    - Se estiver ativa e houver gasto (spendFloat > 0) => green\n    - Se estiver ativa sem gastos => yellow\n  */\n\n  // ❗ Regra nova: se estiver em green mas saldo pré-pago < 100, mostra bolinha amarela (mas continua no bloco verde)\n  const isLowBalance = account.is_prepay_account && saldo !== 9999999 && saldo < 200;\n\n  if (status !== \"ACTIVE\" || saldo === 0) {\n    redAccounts.push({\n      name,\n      spend: spendFormatted,\n      status,\n      saldo_restante: saldoFormatted,\n      emoji: \"❌\",\n      currency,\n    });\n  } else if (spendFloat > 0) {\n    greenAccounts.push({\n      name,\n      spend: spendFormatted,\n      status,\n      saldo_restante: saldoFormatted,\n      emoji: isLowBalance ? \"🟡\" : \"🟢\",\n      currency,\n    });\n  } else {\n    yellowAccounts.push({\n      name,\n      spend: spendFormatted,\n      status,\n      saldo_restante: saldoFormatted,\n      emoji: \"🟡\",\n      currency,\n    });\n  }\n});\n\n// Ordena os arrays por nome em ordem alfabética\ngreenAccounts.sort((a, b) => a.name.localeCompare(b.name));\nredAccounts.sort((a, b) => a.name.localeCompare(b.name));\nyellowAccounts.sort((a, b) => a.name.localeCompare(b.name));\n\n// Função para formatar os dados de uma conta de forma resumida\nconst formatAccount = (account, isRedAccount = false) => {\n  let detail = `${account.emoji} ${account.name} - ${account.currency} ${account.spend}`;\n\n  if (isRedAccount) {\n    detail += ` (Status: ${account.status})`;\n  }\n\n  if (account.saldo_restante !== \"9999999\") {\n    detail += ` (Saldo restante: ${account.currency} ${account.saldo_restante})`;\n  }\n\n  return detail;\n};\n\n// Formata os detalhes de cada categoria, cada conta em uma linha\nconst redLine = redAccounts.length\n  ? redAccounts.map((account) => formatAccount(account, true)).join(\"\\n\")\n  : \"Nenhuma conta\";\n\nconst greenLine = greenAccounts.length\n  ? greenAccounts.map((account) => formatAccount(account)).join(\"\\n\")\n  : \"Nenhuma conta\";\n\nconst yellowLine = yellowAccounts.length\n  ? yellowAccounts.map((account) => formatAccount(account)).join(\"\\n\")\n  : \"Nenhuma conta\";\n\n// Retorna o JSON com cada cor em sua respectiva variável + id_message\nreturn [\n  {\n    json: {\n      id_message,\n      green: `\\n🟢 Contas Ativas com Gastos (`+dataDeOntem()+`):\\n\\n${greenLine} \\n_____`,\n      yellow: `\\n🟡 Contas Ativas sem Gastos (`+dataDeOntem()+`):\\n\\n${yellowLine} \\n_____`,\n      red: `\\n❌ Contas com Problemas ou Sem saldo (`+dataDeOntem()+`):\\n\\n${redLine} \\n_____`,\n    },\n  },\n];\n"},"id":"eb1f72aa-8ab8-4b0f-9563-0d6f58e1baf3","name":"Code: Gera Mensagem Total","type":"n8n-nodes-base.code","typeVersion":2,"position":[3136,-496]},{"parameters":{"jsCode":"/**\n * Processa dados de actions e conversions, integrando-os diretamente no objeto principal.\n * @param {Array} jsonData - Um array de objetos JSON contendo dados a serem processados.\n * @returns {Array} - Um array de objetos JSON processados no formato desejado.\n */\nfunction processData(jsonData) {\n  // Garante que jsonData é um array\n  if (!Array.isArray(jsonData)) {\n    console.error(\"Input não é um array.\");\n    return [];\n  }\n\n  // Processa cada item no array de entrada\n  const processedData = jsonData.map(item => {\n    let data = item.json.data || {};\n    let resultObject = { ...data };\n\n    // Função auxiliar para processar actions ou conversions\n    function processActionsOrConversions(data, key) {\n      if (data && Array.isArray(data)) {\n        data.forEach(dataItem => {\n          const action = dataItem.action_type;\n          const value = dataItem.value;\n          if (action) {\n            resultObject[action] = value;\n          }\n        });\n      }\n    }\n\n    // Processa 'actions' e 'conversions'\n    processActionsOrConversions(data.actions, 'actions');\n    processActionsOrConversions(data.conversions, 'conversions');\n\n    // Remove as propriedades 'actions' e 'conversions' originais\n    delete resultObject.actions;\n    delete resultObject.conversions;\n\n    return resultObject;\n  });\n\n  return processedData;\n}\n\n// Uso da função com o input global\nconst jsonData = $input.all();\nconst result = processData(jsonData);\n\n// Retorna os resultados processados\nreturn result;\n"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[1568,-432],"id":"7bf2c18c-c960-44de-8a82-96a23741f4b1","name":"Code: cleaned > actions > conversions"},{"parameters":{"rule":{"interval":[{"triggerAtHour":7,"triggerAtMinute":30}]}},"id":"70016df5-ee30-4d02-bc11-4381e5be4b49","name":"Diário: 7am","type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.2,"position":[0,-496]},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict","version":2},"conditions":[{"id":"50e7591c-eb63-4335-beac-03350c328696","leftValue":"={{ $json.red }}","rightValue":"Nenhuma conta","operator":{"type":"string","operation":"notContains"}}],"combinator":"and"},"options":{}},"type":"n8n-nodes-base.filter","typeVersion":2.2,"position":[3360,-112],"id":"d730d2e5-f024-4f78-8830-7ee1d30ad40a","name":"Tem conta?"},{"parameters":{"url":"=https://api.clickup.com/api/v2/group","authentication":"predefinedCredentialType","nodeCredentialType":"clickUpOAuth2Api","sendQuery":true,"queryParameters":{"parameters":[{"name":"team_id","value":"37013204"}]},"sendHeaders":true,"headerParameters":{"parameters":[{"name":"accept","value":"application/json"},{"name":"content-type","value":"application/json"}]},"options":{}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.3,"position":[0,-1200],"id":"acec722d-11ed-48dc-98a3-d092f6efb82a","name":"Mensagem Inicial1","credentials":{"clickUpOAuth2Api":{"id":"JtBih6teXSwBbyK9","name":"ClickUp Convertix"}}},{"parameters":{"method":"POST","url":"=https:/