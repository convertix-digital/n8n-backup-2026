xIdDesejado = Number(dados.inbox_id);\n\nconst telefone = String(dados.Whatsapp || '').replace(/\\D/g, '');\n\n// tenta achar o payload em formatos diferentes\nconst payload =\n  Array.isArray($json.payload) ? $json.payload :\n  Array.isArray($json.body?.payload) ? $json.body.payload :\n  Array.isArray($json.data?.payload) ? $json.data.payload :\n  Array.isArray($json[0]?.payload) ? $json[0].payload :\n  [];\n\nconst contato = payload.find(contact => {\n  const identifier = String(contact.identifier || '');\n  const identifierLimpo = identifier.replace(/\\D/g, '');\n  const phoneNumber = String(contact.phone_number || '').replace(/\\D/g, '');\n\n  return (\n    identifier === `${telefone}@s.whatsapp.net` ||\n    identifierLimpo === telefone ||\n    phoneNumber === telefone\n  );\n});\n\nconst contactInboxes = Array.isArray(contato?.contact_inboxes)\n  ? contato.contact_inboxes\n  : [];\n\nconst contactInbox = contactInboxes.find(ci =>\n  Number(ci?.inbox?.id) === inboxIdDesejado\n);\n\nreturn [\n  {\n    json: {\n      found: !!contato,\n      has_correct_inbox: !!contactInbox,\n      should_create: !contato || !contactInbox,\n\n      first_name: dados.first_name,\n      full_name: dados.full_name,\n      Whatsapp: telefone,\n      account_id: dados.account_id,\n      inbox_id: inboxIdDesejado,\n      WABA_ID: dados.WABA_ID,\n\n      contact: {\n        id: contato?.id || null,\n        name: contato?.name || null,\n        phone_number: contato?.phone_number || null,\n        identifier: contato?.identifier || null,\n        source_id: contactInbox?.source_id || null,\n        inbox_id: contactInbox?.inbox?.id || null,\n        inbox_name: contactInbox?.inbox?.name || null,\n        channel_type: contactInbox?.inbox?.channel_type || null,\n        provider: contactInbox?.inbox?.provider || null\n      }\n    }\n  }\n];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[2160,-800],"id":"3e05abce-f68f-473f-ac75-7d070f4ddbef","name":"Pega Contato"},{"parameter