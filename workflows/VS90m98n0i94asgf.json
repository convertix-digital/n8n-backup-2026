acts/{{ $json.payload.id || $('Pega Contato').item.json.contact.id }}/conversations","authentication":"predefinedCredentialType","nodeCredentialType":"chatwootApi","options":{}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.4,"position":[2832,-336],"id":"3280959f-4524-4cbf-abee-903554566f3e","name":"Busca Conversa","credentials":{"chatwootApi":{"id":"zFpwV1tSTRNEkbTI","name":"ChatWoot CONVERTIX"}}},{"parameters":{"jsCode":"const input = $json;\n\n// Dados principais\nconst dados = $('Loop Over Items').item.json;\nconst inboxIdDesejado = Number(dados.inbox_id);\n\n// Fallback do contato, caso exista\nlet sourceIdContato = null;\n\ntry {\n  sourceIdContato =\n    $('Pega Contato').item.json.contact?.source_id ||\n    $('Pega Contato').item.json.source_id ||\n    null;\n} catch (e) {\n  sourceIdContato = null;\n}\n\n// Tenta achar payload em formatos diferentes\nconst conversations =\n  Array.isArray(input.payload) ? input.payload :\n  Array.isArray(input.body?.payload) ? input.body.payload :\n  Array.isArray(input.data?.payload) ? input.data.payload :\n  Array.isArray(input[0]?.payload) ? input[0].payload :\n  [];\n\nconst getTimestamp = (conv) => {\n  const value =\n    conv.last_activity_at ||\n    conv.updated_at ||\n    conv.created_at ||\n    0;\n\n  if (typeof value === 'number') return value;\n\n  const parsed = Date.parse(value);\n  return Number.isNaN(parsed) ? 0 : Math.floor(parsed / 1000);\n};\n\nconst ordenarMaisRecente = (lista) => {\n  return [...lista].sort((a, b) => getTimestamp(b) - getTimestamp(a));\n};\n\nconst conversasInbox = conversations.filter(conv => {\n  return Number(conv?.inbox_id) === inboxIdDesejado;\n});\n\nconst conversasOpen = ordenarMaisRecente(\n  conversasInbox.filter(conv => conv?.status === 'open')\n);\n\nconst conversasPending = ordenarMaisRecente(\n  conversasInbox.filter(conv => conv?.status === 'pending')\n);\n\nconst conversasResolved = ordenarMaisRecente(\n  conversasInbox.filter(conv => conv?.status === 'resolved')\n);\n\nconst conversasOutras = ordenarMaisRecente(\n  conversasInbox.filter(conv =>\n    !['open', 'pending', 'resolved'].includes(conv?.status)\n  )\n);\n\nconst conversaSelecionada =\n  conversasOpen[0] ||\n  conversasPending[0] ||\n  conversasResolved[0] ||\n  conversasOutras[0] ||\n  null;\n\n// Busca source_id em vários caminhos possíveis\nconst sourceId =\n  conversaSelecionada?.contact_inbox?.source_id ||\n  conversaSelecionada?.contact?.contact_inboxes?.find(ci =>\n    Number(ci?.inbox?.id) === inboxIdDesejado\n  )?.source_id ||\n  conversaSelecionada?.messages?.[0]?.conversation?.contact_inbox?.source_id ||\n  conversaSelecionada?.last_non_activity_message?.conversation?.contact_inbox?.source_id ||\n  conversaSelecionada?.last_non_activity_message?.source_id ||\n  sourceIdContato ||\n  null;\n\nreturn [\n  {\n    json: {\n      tem_conversa_inbox: !!conversaSelecionada,\n      conversation_id: conversaSelecionada?.id || null,\n      conversation_status: conversaSelecionada?.status || null,\n      can_reply: conversaSelecionada?.can_reply ?? false,\n\n      inbox_id: conversaSelecionada?.inbox_id || null,\n      inbox_id_desejado: inboxIdDesejado,\n\n      source_id: sourceId,\n\n      precisa_criar_conversa: !conversaSelecionada,\n\n      criterio_selecao: conversaSelecionada\n        ? `conversa_${conversaSelecionada.status || 'sem_status'}_mais_recente`\n        : 'nenhuma_conversa_encontrada',\n\n      total_conversas: conversations.length,\n      total_conversas_inbox: conversasInbox.length,\n      total_open: conversasOpen.length,\n      total_pending: conversasPending.length,\n      total_resolved: conversasResolved.length,\n      total_outras: conversasOutras.length,\n\n      conversa: conversaSelecionada || null\n    }\n  }\n];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[3056,-336],"id":"368e0f50-3426-4f10-9907-5b371bbbbbe3","name":"Pega Conversa"},{"parameters":{"method":"POST","url":"={{ $vars.CHATWOOT_API_URL }}/{{ $('Loop Over Items