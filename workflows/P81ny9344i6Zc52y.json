e() : 0;\n  const dateB = b.criado_em ? new Date(b.criado_em).getTime() : 0;\n\n  if (dateA !== dateB) return dateA - dateB;\n\n  const idA = Number(a.id || 0);\n  const idB = Number(b.id || 0);\n\n  return idA - idB;\n});\n\nconst history = rows.map(row => removePayloadBrutoJsonDeep(row));\n\nreturn [\n  {\n    json: {\n      history\n    }\n  }\n];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[1776,-48],"id":"f56c840c-de81-4f80-9f6c-3208355f5d2e","name":"history"},{"parameters":{"mode":"combine","combineBy":"combineByPosition","options":{}},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[2000,-112],"id":"79800b37-80f4-4ae6-ac94-8f100bb9ae94","name":"Merge1"},{"parameters":{"assignments":{"assignments":[{"id":"b2a8cbca-fe9f-453e-bef1-24dd314444a9","name":"text","value":"={{ $json.toJsonString().replaceAll(\"Julia Gabriela\",\"Bruna Auau\") }}","type":"string"}]},"options":{}},"type":"n8n-nodes-base.set","typeVersion":3.4,"position":[2224,-112],"id":"b56ee91b-d4ea-4434-bf7e-8fcbc10332fa","name":"Gera text"},{"parameters":{},"type":"n8n-nodes-base.noOp","typeVersion":1,"position":[1328,-112],"id":"a37b0681-2f63-4340-825f-922c1d3b557b","name":"No Operation, do nothing","executeOnce":true}],"connections":{"Gmail Trigger":{"main":[[{"node":"Edit Fields","type":"main","index":0},{"node":"Delete a message","type":"main","index":0}]]},"Edit Fields":{"main":[[{"node":"Convert to File","type":"main","index":0}]]},"Convert to File":{"main":[[{"node":"Upload file","type":"main","index":0}]]},"Webhook":{"main":[[{"node":"Gera Resumo Histórico Longo","type":"main","index":0}]]},"Convert to File1":{"main":[[{"node":"Upload file1","type":"main","index":0}]]},"Dados do Lead":{"main":[[{"node":"Memory","type":"main","index":0},{"node":"Merge","type":"main","index":0}]]},"Merge":{"main":[[{"node":"Merge1","type":"main","index":0},{"node":"No Operation, do nothing","type":"main","index":0}]]},"Gera Resumo Histórico Longo":{"main":[[{"node":"Dados do Lead","typ