ms = $input.all();\n\nfunction removePayloadBrutoJsonDeep(value) {\n  if (Array.isArray(value)) {\n    return value.map(removePayloadBrutoJsonDeep);\n  }\n\n  if (value && typeof value === 'object') {\n    const cleaned = {};\n\n    for (const [key, val] of Object.entries(value)) {\n      if (key === 'payload_bruto_json') continue;\n\n      cleaned[key] = removePayloadBrutoJsonDeep(val);\n    }\n\n    return cleaned;\n  }\n\n  return value;\n}\n\n// Suporta dois cenários:\n// 1. Várias linhas vindo como vários items do n8n\n// 2. Um único item contendo um array direto\nlet rows = [];\n\nif (inputItems.length === 1 && Array.isArray(inputItems[0].json)) {\n  rows = inputItems[0].json;\n} else if (inputItems.length === 1 && Array.isArray(inputItems[0].json.history)) {\n  rows = inputItems[0].json.history;\n} else if (inputItems.length === 1 && Array.isArray(inputItems[0].json.data)) {\n  rows = inputItems[0].json.data;\n} else {\n  rows = inputItems.map(item => item.json);\n}\n\n// Ordena cronologicamente, se tiver criado_em ou id\nrows.sort((a, b) => {\n  const dateA = a.criado_em ? new Date(a.criado_em).getTime() : 0;\n  const dateB = b.criado_em ? new Date(b.criado_em).getTime() : 0;\n\n  if (dateA !== dateB) return dateA - dateB;\n\n  const idA = Number(a.id || 0);\n  const idB = Number(b.id || 0);\n\n  return idA - idB;\n});\n\nconst history = rows.map(row => removePayloadBrutoJsonDeep(row));\n\nreturn [\n  {\n    json: {\n      history\n    }\n  }\n];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[1568,-48],"id":"f56c840c-de81-4f80-9f6c-3208355f5d2e","name":"history"},{"parameters":{"mode":"combine","combineBy":"combineByPosition","options":{}},"type":"n8n-nodes-base.merge","typeVersion":3.2,"position":[1792,-112],"id":"79800b37-80f4-4ae6-ac94-8f100bb9ae94","name":"Merge1"},{"parameters":{"assignments":{"assignments":[{"id":"b2a8cbca-fe9f-453e-bef1-24dd314444a9","name":"text","value":"={{ $json.toJsonString().replaceAll(\"Julia Gabriela\",\"Bruna Auau