ource_id ||\n  contact.source_id ||\n  null;\n\nconst conversaLabels = conversaSelecionada?.labels ?? [];\n\nreturn [\n  {\n    json: {\n      tem_conversa_inbox: !!conversaSelecionada,\n      conversation_id: conversaSelecionada?.id || null,\n      conversation_status: conversaSelecionada?.status || null,\n      can_reply: conversaSelecionada?.can_reply ?? false,\n      account_id: contact.account_id,\n      contact_id: contact.contact_id,\n      identifier: contact.identifier,\n      phone_number: contact.phone_number,\n      inbox_id: conversaSelecionada?.inbox_id || null,\n      inbox_id_desejado: contact.inbox_id_desejado,\n      source_id: sourceId,\n      precisa_criar_conversa: !conversaSelecionada,\n      criterio_selecao: conversaSelecionada\n        ? `conversa_${conversaSelecionada.status || 'sem_status'}_mais_recente`\n        : 'nenhuma_conversa_encontrada',\n      total_conversas_inbox: conversasInbox.length,\n      total_open: conversasOpen.length,\n      total_pending: conversasPending.length,\n      total_resolved: conversasResolved.length,\n      labels: conversaLabels,\n      status: conversaSelecionada?.status || \"\"\n      // conversa: conversaSelecionada\n    }\n  }\n];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[224,288],"id":"5b1cc308-1d2a-4ebc-86cb-906c25814003","name":"Pega Conversa"},{"parameters":{"url":"={{ $vars.CHATWOOT_API_URL }}/{{ $json.account_id }}/contacts/{{ $json.contact_id }}/conversations","authentication":"predefinedCredentialType","nodeCredentialType":"chatwootApi","options":{}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.4,"position":[0,288],"id":"1b3c3aff-17d7-44e5-a7d4-8d8f8df3313d","name":"Busca Conversa","credentials":{"chatwootApi":{"id":"zFpwV1tSTRNEkbTI","name":"ChatWoot CONVERTIX"}}},{"parameters":{"method":"POST","url":"={{ $vars.CHATWOOT_API_URL }}/{{ $('Start').item.json.account_id }}/contacts","authentication":"predefinedCredentialType","nodeCredentialType":"chatwootApi","sendBody":true