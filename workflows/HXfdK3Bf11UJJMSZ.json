{"updatedAt":"2026-04-05T05:02:49.277Z","createdAt":"2026-01-06T04:13:42.427Z","id":"HXfdK3Bf11UJJMSZ","name":"[CTX] [INTERNO] Análise Diária Grupos","active":false,"isArchived":true,"nodes":[{"parameters":{"jsCode":"// Objeto para consolidar os dados por grupo (subject)\nconst groupedData = {};\n\n// Itera sobre os itens de entrada\nfor (const item of $('MySQL: Interações').all()) {\n  const dataArray = item.json.data; // Acessa o array \"data\" corretamente\n\n  // Itera sobre cada item dentro do array \"data\"\n  for (const data of dataArray) {\n    // Ignora itens sem mensagens\n    if (data.qtdMsg > 0) {\n      // Se o grupo ainda não foi registrado, inicializa\n      if (!groupedData[data.subject]) {\n        groupedData[data.subject] = {\n          totalMessages: 0,\n          senders: [],\n        };\n      }\n\n      // Incrementa o total de mensagens do grupo\n      groupedData[data.subject].totalMessages += data.qtdMsg;\n\n      // Adiciona o remetente e a quantidade de mensagens ao grupo\n      groupedData[data.subject].senders.push(`- ${data.senderName}: ${data.qtdMsg}`);\n    }\n  }\n}\n\n// Monta o resultado consolidado\nconst result = [];\nfor (const [subject, groupData] of Object.entries(groupedData)) {\n  // Cria a mensagem consolidada para cada grupo\n  const formattedMessage = `Grupo: **${subject}**: ${groupData.totalMessages}\\n${groupData.senders.join('\\n')}`;\n  result.push({ message: formattedMessage, totalMessages: groupData.totalMessages });\n}\n\n// Ordena os grupos pelo total de mensagens em ordem decrescente\nresult.sort((a, b) => b.totalMessages - a.totalMessages);\n\n// Retorna o array de mensagens formatadas (removendo a propriedade auxiliar \"totalMessages\")\nreturn result.map(({ message }) => ({ message }));\n"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[256,176],"id":"07a53a4f-1576-44c8-a2b4-15f35127ca5b","name":"Interações"},{"parameters":{"resource":"message","guildId":{"__rl":true,"value":"1083176019504140348","m