rupo.\n\nEntão já aproveita para entrar agora. 👇🏼\n\nhttps://chat.whatsapp.com/F1SGHAardzGJXyXLlc8m0o`,\n\n`Olá {{nome}}! ❤️\n\nPassando para confirmar sua inscrição e compartilhar algumas informações importantes.\n\n🏥 Oficina de Protocolos em Nutrição Hospitalar\n\n📅 27/06\n⏰ 10h às 13h\n\nA aula acontecerá pelo Zoom.\n\n⚠️ O link será enviado somente no grupo do WhatsApp, no sábado pela manhã.\n\nTambém vale conferir se seu aplicativo do Zoom está atualizado para evitar atrasos.\n\nEntre agora no grupo para garantir que vai receber todas as informações:\n\n👇🏼\nhttps://chat.whatsapp.com/F1SGHAardzGJXyXLlc8m0o`,\n\n`Oi {{nome}}! 😊\n\nFalta pouco para nossa Oficina de Protocolos em Nutrição Hospitalar!\n\n🗓️ 27/06\n⏰ Das 10h às 13h\n\nA aula será realizada pelo Zoom.\n\nO link será enviado apenas no grupo do WhatsApp.\n\nAntes da aula, confira se o Zoom está atualizado no seu celular ou computador. Assim você evita qualquer atraso.\n\nJá entra no grupo para receber o acesso no sábado cedinho. 🎯\n\n👇🏼\nhttps://chat.whatsapp.com/F1SGHAardzGJXyXLlc8m0o`,\n\n`Oie {{nome}}! 💚\n\nEstamos muito felizes por ter você na Oficina de Protocolos em Nutrição Hospitalar!\n\n📅 27/06\n⏰ 10h às 13h\n\nA transmissão será pelo Zoom.\n\nO link será enviado exclusivamente no grupo do WhatsApp no sábado pela manhã.\n\nSó não esquece de atualizar o Zoom antes da aula para evitar qualquer contratempo.\n\nSe ainda não entrou no grupo, aproveita agora:\n\n👇🏼\nhttps://chat.whatsapp.com/F1SGHAardzGJXyXLlc8m0o`\n\n];\n\nreturn $input.all().map(item => {\n\n    const nome = (item.json.Nome || \"Nutri\").trim();\n\n    const celular = String(item.json.Celular || \"\")\n        .replace(/\\D/g, \"\");\n\n    // Soma dos dígitos do telefone para escolher sempre a mesma mensagem\n    const soma = celular\n        .split(\"\")\n        .reduce((total, digito) => total + Number(digito), 0);\n\n    const indice = soma % mensagens.length;\n\n    item.json.mensagem = mensagens[indice]\n        .replaceAll(\"{{nome}}\", nome);\n\n    return item;\n\n});"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[1296,-1120],"id":"5da3d37a-050d-4200-a818-43f2307102a5","name":"Gera Mensagem"},{"parameters":{"resource":"messages-api","instanceName":"ctxoperacoes","remoteJid":"=120363417179974709@g.us","messageText":"=Enviei todas as mensagens. Link pra validar.\nhttps://docs.google.com/spreadsheets/d/1x7xRJVLUaqif72FHPyntIs2x6uwbT9NS2quDnTAWPKk/edit?pli=1&gid=0#gid=0","options_message":{}},"type":"n8n-nodes-evolution-api.evolutionApi","typeVersion":1,"position":[1968,-1312],"id":"260f671a-2283-4028-bf2a-e81df4a21f63","name":"Avisa fim","credentials":{"evolutionApi":{"id":"YetnRlRJ2NuSYY8K","name":"EVO ctxoperacoes"}}},{"parameters":{"rule":{"interval":[{"triggerAtHour":8}]}},"type":"n8n-nodes-base.scheduleTrigger","typeVersion":1.3,"position":[176,-1120],"id":"84f66ead-ebfb-4522-821f-5f39db42f373","name":"Schedule Trigger"},{"parameters":{"operation":"update","documentId":{"__rl":true,"value":"1x7xRJVLUaqif72FHPyntIs2x6uwbT9NS2quDnTAWPKk","mode":"id"},"sheetName":{"__rl":true,"value":"gid=0","mode":"list","cachedResultName":"Página1","cachedResultUrl":"https://docs.google.com/spreadsheets/d/1x7xRJVLUaqif72FHPyntIs2x6uwbT9NS2quDnTAWPKk/edit#gid=0"},"columns":{"mappingMode":"defineBelow","value":{"row_number":"={{ $('Loop Over Items').item.json.row_number }}","enviou?":"={{ $('Loop Over Items').item.json.mensagem }}"},"matchingColumns":["row_number"],"schema":[{"id":"Nome","displayName":"Nome","required":false,"defaultMatch":false,"display":true,"type":"string","canBeUsedToMatch":true,"removed":true},{"id":"Celular","displayName":"Celular","required":false,"defaultMatch":false,"display":true,"type":"string","canBeUsedToMatch":true,"removed":true},{"id":"enviou?","displayName":"enviou?","required":false,"defaultMatch":false,"display":true,"type":"string","canBeUsedToMatch":true,"removed":false},{"id":"row_number","displayName":"row_number","required":false,"defaultMatch":fal